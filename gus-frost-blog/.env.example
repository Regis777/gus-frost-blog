# Copie ce fichier en .env (non versionne) et remplis les valeurs.
# NE JAMAIS committer le .env reel. (deja exclu par .gitignore)

# --- Shopify Admin API ---
# Domaine technique de la boutique, ex. baby-french.myshopify.com
SHOPIFY_STORE_DOMAIN=

# Auth recommandee (apps Dev Dashboard, depuis 2026) : Client Credentials Grant.
# Le script echange ces identifiants contre un token (valide ~24 h, mis en cache local).
# L'app doit etre INSTALLEE sur le store et avoir les scopes write_content + read_content.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Alternative (anciennes apps avec token permanent shpat_...). Laisser vide si CCG.
SHOPIFY_ADMIN_TOKEN=

# Version de l'API Admin (laisser par defaut si tu ne sais pas)
SHOPIFY_API_VERSION=2024-10

# --- Cible blog & commerce ---
# Handle du blog cible (URL finale : /blogs/<handle>/<slug>)
BLOG_HANDLE=chiens
# Handle de la collection "Stress - Anxiete"
COLLECTION_HANDLE=stress

# --- Optionnel : handles produits (non requis : aucun lien produit dans les corps) ---
PRODUCT_GILET_HANDLE=
PRODUCT_TAPIS_FOUILLE_HANDLE=
PRODUCT_TAPIS_LECHAGE_HANDLE=
