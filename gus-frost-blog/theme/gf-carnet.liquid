{%- comment -%}
  Section « Le Carnet » — carnet de santé / rappels / budget / souvenirs.
  Web app 100 % côté navigateur : aucune donnée n'est envoyée à Shopify ni ailleurs.
  Pré-requis : assets/gf-carnet.css et assets/gf-carnet.js déposés dans le thème.
  Une seule section « Le Carnet » par page (l'app est un singleton).
{%- endcomment -%}

{{ 'gf-carnet.css' | asset_url | stylesheet_tag }}

<div class="gfc-app" id="gfc-{{ section.id }}">

  <header class="gfc-head">
    {%- if section.settings.heading != blank -%}
      <h1>{{ section.settings.heading | escape }}</h1>
    {%- endif -%}
    {%- if section.settings.tagline != blank -%}
      <p>{{ section.settings.tagline | escape }}</p>
    {%- endif -%}
    {%- if section.settings.show_privacy -%}
      <p><span class="gfc-privacy">🔒 {{ section.settings.privacy_label | escape }}</span></p>
    {%- endif -%}
  </header>

  <div class="gfc-petbar" data-gfc-petbar></div>

  <nav class="gfc-tabs" data-gfc-tablist aria-label="Rubriques du carnet">
    <button type="button" class="gfc-tab" data-gfc-tab="identite"  aria-selected="true">Identité</button>
    <button type="button" class="gfc-tab" data-gfc-tab="sante"     aria-selected="false">Santé</button>
    <button type="button" class="gfc-tab" data-gfc-tab="rappels"   aria-selected="false">Rappels</button>
    <button type="button" class="gfc-tab" data-gfc-tab="budget"    aria-selected="false">Budget</button>
    <button type="button" class="gfc-tab" data-gfc-tab="souvenirs" aria-selected="false">Souvenirs</button>
  </nav>

  <div data-gfc-panels aria-live="polite"></div>

  <section class="gfc-tools" data-gfc-tools>
    <h2>Sauvegarde &amp; partage</h2>
    <p class="gfc-hint">
      Le carnet vit dans ce navigateur, sur cet appareil. Vider les données de navigation
      l’effacerait&nbsp;: exportez une sauvegarde de temps en temps, c’est votre filet.
    </p>
    <div class="gfc-tools-grid">
      <button type="button" class="gfc-btn gfc-btn--sm gfc-btn--primary" data-act="print">🖨️ Carnet PDF</button>
      <button type="button" class="gfc-btn gfc-btn--sm" data-act="ics">📅 Agenda (.ics)</button>
      <button type="button" class="gfc-btn gfc-btn--sm" data-act="share">🔗 Partager la fiche</button>
      <button type="button" class="gfc-btn gfc-btn--sm" data-act="export">⬇️ Exporter ma sauvegarde</button>
      <button type="button" class="gfc-btn gfc-btn--sm" data-act="import">⬆️ Restaurer une sauvegarde</button>
      <button type="button" class="gfc-btn gfc-btn--sm gfc-btn--danger" data-act="raz">Tout effacer</button>
    </div>
    <p class="gfc-hint" style="margin-top:14px">
      <strong>Astuce&nbsp;:</strong> ajoutez cette page à votre écran d’accueil pour l’ouvrir comme une application.
      Sur iPhone, bouton <em>Partager</em> puis <em>Sur l’écran d’accueil</em>&nbsp;;
      sur Android, menu <em>⋮</em> puis <em>Ajouter à l’écran d’accueil</em>.
    </p>
    <input type="file" accept="application/json,.json" data-gfc-import hidden>
  </section>

  {%- if section.settings.cta_heading != blank -%}
    <aside class="gfc-cta">
      <h2>{{ section.settings.cta_heading | escape }}</h2>
      {%- if section.settings.cta_text != blank -%}
        <p>{{ section.settings.cta_text | escape }}</p>
      {%- endif -%}
      {%- if section.settings.cta_url != blank and section.settings.cta_label != blank -%}
        <a class="gfc-btn" href="{{ section.settings.cta_url }}">{{ section.settings.cta_label | escape }}</a>
      {%- endif -%}
    </aside>
  {%- endif -%}

  <div class="gfc-modal" data-gfc-modal hidden></div>
  <div class="gfc-toast" data-gfc-toast hidden role="status"></div>
</div>

<script src="{{ 'gf-carnet.js' | asset_url }}" defer></script>
<script>
  (function () {
    var el = document.getElementById('gfc-{{ section.id }}');
    if (!el) return;
    (function attendre() {
      if (window.GFCarnet && window.GFCarnet.init) { window.GFCarnet.init(el); }
      else { setTimeout(attendre, 50); }
    })();
  })();
</script>

{% schema %}
{
  "name": "Le Carnet",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Le Carnet"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Accroche",
      "default": "Vaccins, rappels, poids, budget, souvenirs : tout le suivi de vos animaux au même endroit. Gratuit, sans compte, sans publicité."
    },
    {
      "type": "checkbox",
      "id": "show_privacy",
      "label": "Afficher le bandeau de confidentialité",
      "default": true
    },
    {
      "type": "text",
      "id": "privacy_label",
      "label": "Texte du bandeau",
      "default": "Vos données restent sur votre appareil"
    },
    {
      "type": "header",
      "content": "Encart boutique (bas de page)"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "Titre de l'encart",
      "default": "Un compagnon plus serein au quotidien ?"
    },
    {
      "type": "textarea",
      "id": "cta_text",
      "label": "Texte de l'encart",
      "default": "Nos guides et nos accessoires pour l'anxiété, le calme et la mastication."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Libellé du bouton",
      "default": "Découvrir la boutique"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Lien du bouton"
    }
  ],
  "presets": [{ "name": "Le Carnet" }]
}
{% endschema %}
